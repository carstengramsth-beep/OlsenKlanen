{
  "rules": {
    // Presence – OlsenBanden admin-panel (ingen Firebase Auth påkrævet)
    "presence": {
      ".read": true,
      ".write": true
    },
 
    // Gruppechat – OlsenBanden admin-panel
    "chat": {
      ".read": true,
      ".write": true
    },
 
    // Videomøde-invitationer – OlsenBanden admin-panel
    "invites": {
      ".read": true,
      ".write": true
    },
 
    // Online-status – OlsenBanden videofon (olsenbanden.html)
    "online": {
      ".read": true,
      ".write": true
    },
 
    // Beskeder – OlsenBanden videofon (olsenbanden.html)
    "beskeder": {
      ".read": true,
      ".write": true
    },
 
    // Opkald – OlsenBanden videofon (olsenbanden.html)
    "opkald": {
      ".read": true,
      ".write": true
    },
 
    // Videofon Møde Rum – tilmeldte medlemmer (videofon-moederum.html)
    "videofon_moederum": {
      ".read": true,
      ".write": true
    },
 
    // Videofon Møde Rum – opkald mellem tilmeldte (videofon-moederum.html)
    "vmr_opkald": {
      ".read": true,
      ".write": true
    },
 
    // Medlemmer – mærket "fri for kald" (klar til kartoteket senere)
    "medlemmer": {
      ".read": true,
      ".write": true
    },
 
    // Hilsener – alle kan læse og oprette nye (kode-tjek sker i klienten)
    "hilsener": {
      "$tilKey": {
        ".read": true,
        "$id": {
          ".write": "!data.exists()",
          ".validate": "newData.hasChildren(['fra','besked','tidspunkt']) && newData.child('fra').isString() && newData.child('fra').val().length > 0 && newData.child('besked').isString() && newData.child('besked').val().length > 0"
        }
      }
    },
 
    // Vil ikke forstyrres – OlsenBanden admin-panel
    "dnd": {
      ".read": true,
      ".write": true
    },
 
    // Ubesvarede opkald – OlsenBanden admin-panel
    "missedCall": {
      ".read": true,
      ".write": true
    },
 
    // Afvis al anden adgang
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
 
