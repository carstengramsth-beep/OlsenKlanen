{
  "rules": {
    "presence": {
      // Kun autentificerede brugere må se presence-listen
      ".read": "auth != null",
      "$userKey": {
        // Kun autentificerede brugere må skrive — nøglen er email med '.' erstattet af ','
        // Firebase RTDB understøtter ikke string-replace i regler, så vi
        // tillader enhver autentificeret bruger at skrive sin egen node.
        // Adgangskontrol på kollektionsniveau sker i Firestore (brugere-samlingen).
        ".write": "auth != null"
      }
    },
    // Hilsener – alle kan læse og oprette nye (kode-tjek sker i klienten)
    "hilsener": {
      "$tilKey": {
        ".read": true,
        "$id": {
          ".write": "!data.exists()",
          ".validate": "newData.hasChildren(['fra','besked','tidspunkt']) && newData.child('fra').isString() && newData.child('fra').val().length > 0 && newData.child('besked').isString() && newData.child('besked').val().length > 0"
        }
      }
    },
    // Afvis al anden adgang
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
